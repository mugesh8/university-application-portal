# API base URL for `src/config/baseUrl.js` (`VITE_API_BASE_URL`).
# Keep exactly ONE of the two lines below uncommented. Restart `npm run dev` or rebuild after changes.
# For production builds / deployment, uncomment the live URL (not localhost).

# --- Live (production) ---
VITE_API_BASE_URL=https://newapply.muantigua.org

# --- Local API (change port if your backend uses another) ---
# VITE_API_BASE_URL=http://localhost:3000
